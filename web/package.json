{
  "name": "kirchhoff-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync-wasm": "cp ../build-wasm-ng/kirchhoff.js public/",
    "dev": "npm run sync-wasm && vite",
    "build": "npm run sync-wasm && vite build",
    "preview": "vite preview",
    "test:unit": "node --test 'tests/lib/*.test.js'",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test smoke",
    "test": "npm run test:unit && npm run test:e2e"
  },
  "dependencies": {
    "vue": "^3.5.24"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "vite": "^7.2.2"
  }
}
